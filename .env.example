# Ritmo Project - Environment Variables Template
# Copie este arquivo para .env e ajuste os valores conforme necessário

# ================================
# DATABASE CONFIGURATION
# ================================
POSTGRES_DB=ritmo_db
POSTGRES_USER=ritmo_user
POSTGRES_PASSWORD=your_secure_password_here

# ================================
# DJANGO CONFIGURATION
# ================================
SECRET_KEY=your-very-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ================================
# FRONTEND CONFIGURATION
# ================================
VITE_API_URL=http://localhost:8000

# ================================
# REDIS CONFIGURATION (opcional)
# ================================
REDIS_PASSWORD=your_redis_password_here

# ================================
# EMAIL CONFIGURATION (opcional)
# ================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True

# ================================
# AWS S3 CONFIGURATION (opcional)
# ================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_REGION_NAME=us-east-1

# ================================
# MONITORING (opcional)
# ================================
SENTRY_DSN=your_sentry_dsn_here

# ================================
# SSL/HTTPS (produção)
# ================================
USE_HTTPS=True
SECURE_SSL_REDIRECT=True
