# ============================================================================
# Ritmo — Variáveis de Ambiente
# ============================================================================
# Copie este arquivo para .env e preencha os valores.
#
# DESENVOLVIMENTO: docker compose up --build
# PRODUÇÃO:        docker compose -f docker-compose.prod.yml up -d --build
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=ritmo_db
POSTGRES_USER=ritmo_user
POSTGRES_PASSWORD=CHANGE_ME_secure_password

# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_python_c_from_django_core_management_utils_import_get_random_secret_key_print_get_random_secret_key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,ritmo.app,www.ritmo.app

# ── Frontend ────────────────────────────────────────────────────────────────
# Em dev: http://localhost:8000
# Em prod: https://ritmo.app (ou o domínio que usar)
VITE_API_URL=https://ritmo.app

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Celery ──────────────────────────────────────────────────────────────────
# USE_ASYNC_EXPORT=false em dev para exports síncronos (mais fácil de debugar)
# USE_ASYNC_EXPORT=true em prod para fila assíncrona com prioridade
USE_ASYNC_EXPORT=true
CELERY_CONCURRENCY=4
GUNICORN_WORKERS=4

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (SMTP) ───────────────────────────────────────────────────────────
# Em dev, usar: EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@ritmo.app
EMAIL_HOST_PASSWORD=CHANGE_ME
DEFAULT_FROM_EMAIL=Ritmo <noreply@ritmo.app>

# ── OAuth (Social Login) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── SSL / Domínio (produção) ───────────────────────────────────────────────
DOMAIN=ritmo.app
CERTBOT_EMAIL=admin@ritmo.app

# ── AWS (deploy) ───────────────────────────────────────────────────────────
# Estas variáveis são usadas no GitHub Actions (Secrets), não no .env local.
# AWS_ACCOUNT_ID=123456789012
# AWS_DEPLOY_ROLE_ARN=arn:aws:iam::123456789012:role/ritmo-deploy
# EC2_HOST=ec2-xx-xx-xx-xx.sa-east-1.compute.amazonaws.com
# EC2_USER=ubuntu
# EC2_SSH_KEY=(chave privada SSH)

# ── Monitoring (opcional) ──────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
